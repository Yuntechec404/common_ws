<launch>
<node pkg="forklift_server" type="ctrl_server.py" name="ctrl_server" output="screen">
    <!-- :HACK: 要改成可以設定層數的（scripts/PBVS_server_minicar.py） -->
    <rosparam param="command">
    [
        ['TopologyMap', 'P3'],
        ['PBVS', 'parking_bodycamera', 2], 
        ['PBVS', 'raise_pallet', 2],
        ['TopologyMap', 'P7'],
        ['PBVS', 'parking_bodycamera', 2],
        ['PBVS', 'drop_pallet', 2],
        ['PBVS', 'parking_bodycamera', 1],
        ['PBVS', 'raise_pallet', 1],
        ['TopologyMap', 'P11'],
        ['PBVS', 'parking_bodycamera', 1],
        ['PBVS', 'drop_pallet', 1],
        ['TopologyMap', 'P14']
    ]
    </rosparam>
</node>
</launch>
